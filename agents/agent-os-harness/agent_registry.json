      "runtime": "ollama_cloud",
      "endpoint": "http://localhost:11434/api/generate",
      "model": "deepseek-v4-flash:cloud",
      "tools": [
        "completion",
        "json"
      ],
      "dispatch_format": "api_call",
      "priority": 5,
      "enabled": true,
      "note": "Kimi API suspended; routed to Ollama Cloud via local Ollama"
    },
    {
      "id": "ollama_cloud",
      "name": "Ollama Cloud Models",
      "role": "local_fallback",
      "runtime": "ollama",
      "endpoint": "http://127.0.0.1:11434",
