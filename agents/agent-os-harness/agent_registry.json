{
  "version": "2026-06-30",
  "emperor": {
    "id": "emperor",
    "name": "Emperor Agent",
    "role": "orchestrator",
    "runtime": "claude-code",
    "endpoint": "local",
    "tools": [
      "dispatch",
      "read_memory",
      "write_memory",
      "score_dopamine",
      "ship"
    ],
    "priority": 0
  },
  "agents": [
    {
      "id": "openclaw_main",
      "name": "OpenClaw Main Agent",
      "role": "local_tool_orchestrator",
      "runtime": "openclaw",
      "endpoint": "openclaw agent --agent main --message <task>",
      "tools": [
        "mcp",
        "exec",
        "browser",
        "file",
        "cron"
      ],
      "dispatch_format": "openclaw_agent",
      "priority": 1,
      "enabled": true,
      "model": "ollama/glm-5.2:cloud"
    },
    {
      "id": "hermes_orchestrator",
      "name": "Hermes Agent",
      "role": "skill_runtime",
      "runtime": "hermes-cli",
      "endpoint": "~/.hermes/hermes-agent",
      "tools": [
        "skills",
        "telegram",
        "memory",
        "subagents"
      ],
      "dispatch_format": "hermes_skill",
      "priority": 2,
      "enabled": true
    },
    {
      "id": "claude_code",
      "name": "Claude Code",
      "role": "deep_engineering",
      "runtime": "claude-code",
      "endpoint": "local",
      "tools": [
        "edit",
        "test",
        "git",
        "skills"
      ],
      "dispatch_format": "claude_prompt",
      "priority": 3,
      "enabled": true
