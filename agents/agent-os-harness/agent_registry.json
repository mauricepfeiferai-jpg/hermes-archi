        "glm-5.2:cloud",
        "kimi-k2.7-code:cloud",
        "deepseek-v4-flash:cloud"
      ],
      "tools": [
        "completion"
      ],
      "dispatch_format": "ollama_chat",
      "priority": 6,
      "enabled": true,
      "note": "cloud aliases only, no auto-fallback per memory decision 2026-06-26"
