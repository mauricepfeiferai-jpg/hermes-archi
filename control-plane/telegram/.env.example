# ── Core4 Telegram Bot — Environment Template ─────────────────────────────────
# Copy to: integrations/telegram/.env
# Then fill in the values below.

# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Forum Topic IDs (get from Telegram after creating topics) ─────────────────
# Right-click topic → Copy Link → extract last number from URL
TELEGRAM_TOPIC_JARVIS=
TELEGRAM_TOPIC_HERMES=
TELEGRAM_TOPIC_OPENCLAW=
TELEGRAM_TOPIC_HARVEY=

# ── Core4 Agent URLs (defaults work for local deploy) ─────────────────────────
JARVIS_URL=http://127.0.0.1:18791
HERMES_URL=http://127.0.0.1:18790
OPENCLAW_URL=http://127.0.0.1:18789
HARVEY_URL=http://127.0.0.1:18792

# ── Admin (optional: restricts /exec to this Telegram user ID) ────────────────
TELEGRAM_ADMIN_ID=

# ── Channel for promo posts (optional) ────────────────────────────────────────
TELEGRAM_TARGET_CHANNEL=

# ── AI Provider (Ollama recommended — no API spend) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
AI_MODEL=qwen3:32b

# ── Harvey / Legal (optional) ─────────────────────────────────────────────────
# BOT_PERSONA=harvey       # legacy single-persona override (omit for topic routing)
STRIPE_PAYMENT_LINK=
LEGAL_MONTHLY_PRICE=49€
LEGAL_PER_DOC_PRICE=9€

# ── Legacy M0Claw single-persona mode (optional, omit for topic routing) ──────
# BOT_PERSONA=jarvis|hermes|openclaw|harvey
