{
  "name": "jarvis",
  "role": "Personal Orchestrator",
  "version": "1.0.0",
  "port": 18791,
  "endpoint": "http://127.0.0.1:18791",
  "model": {
    "reasoning": "ollama/qwen3:32b",
    "embedding": "ollama/nomic-embed-text",
    "temperature": 0.7,
    "maxTokens": 8192
  },
  "memory": {
    "backend": "core-engine",
    "coreApiUrl": "http://127.0.0.1:3000/api/v1",
    "vectorDb": {
      "path": "/root/galaxia/vector_db",
      "embedModel": "nomic-embed-text",
      "autoIndex": true,
      "indexInterval": "1h"
    },
    "retentionDays": 365
  },
  "capabilities": [
    "memory",
    "orchestration",
    "conversation",
    "intent_classification"
  ],
  "bus": {
    "hermesUrl": "http://127.0.0.1:18790",
    "registerOnStart": true,
    "heartbeatInterval": 30
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "topicId": 1,
      "topicName": "Jarvis — Personal"
    },
    "cli": {
      "enabled": true,
      "command": "jarvis"
    },
    "mcp": {
      "enabled": true,
      "name": "jarvis-memory",
      "exposeAs": ["memory_recall", "memory_write", "intent_route"]
    }
  },
  "skills_proxy": [
    "web-research",
    "trend-scanner",
    "fact-checker"
  ],
  "boundaries": {
    "maxDelegationHops": 1,
    "requireConfirmationFor": ["spend", "publish", "send_email"],
    "spendThresholdEur": 50
  },
  "language": "de",
  "soul_file": "./SOUL.md"
}
