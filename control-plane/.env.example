# Pfeifer Core4 — Environment Variables Template
# Copy to .env and fill in values. Do NOT commit .env.

# -------- Ollama (local, zero-cost LLM) --------
OLLAMA_URL=http://localhost:11434

# -------- Models --------
# qwen3:30b-a3b is MoE (3B active params) — same quality, ~4x faster than full 32b.
# Use for interactive agents (Jarvis, OpenClaw). Harvey keeps deepseek-r1:32b for reasoning.
JARVIS_MODEL=qwen3:30b-a3b
JARVIS_EMBED_MODEL=nomic-embed-text
OPENCLAW_MODEL=qwen3:30b-a3b
HARVEY_MODEL=deepseek-r1:32b
HARVEY_FALLBACK_MODEL=qwen3:30b-a3b

# -------- Ports (loopback) --------
# Core4 runs on the 188xx range to avoid colliding with the legacy
# OpenClaw gateway (which already owns :18789) and other live services.
HERMES_PORT=18890
JARVIS_PORT=18891
OPENCLAW_PORT=18892
HARVEY_PORT=18893

# -------- Internal URLs --------
HERMES_URL=http://127.0.0.1:18890
JARVIS_URL=http://127.0.0.1:18891
OPENCLAW_URL=http://127.0.0.1:18892
HARVEY_URL=http://127.0.0.1:18893

# -------- Storage paths --------
HERMES_KG_DB=/var/lib/hermes/knowledge_graph.db
JARVIS_MEMORY_DB=/var/lib/jarvis/memory.db
GOALS_DIR=/var/lib/hermes/goals
HARVEY_USAGE_DIR=/var/lib/harvey/legal_usage

# -------- OpenClaw bridges --------
# Leave unset to auto-resolve relative to the repo (recommended).
# Only set these if your .openclaw config lives outside the repo.
#OPENCLAW_CONFIG=/path/to/repo/.openclaw/openclaw.json
#OPENCLAW_WORKSPACE=/path/to/repo/openclaw/workspace/skills

# -------- Harvey monetization --------
HARVEY_FREE_REVIEWS=2
STRIPE_PAYMENT_LINK=
STRIPE_WEBHOOK_SECRET=
LEGAL_MONTHLY_PRICE=49€
LEGAL_PER_DOC_PRICE=9€

# -------- Logging --------
LOG_LEVEL=INFO
