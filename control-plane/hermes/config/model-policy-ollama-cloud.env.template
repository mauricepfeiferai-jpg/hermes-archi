# Hermes model policy — Ollama Cloud Edition
# Kimi API suspended; use Ollama Cloud models via local Ollama HTTP API.

HERMES_MODEL_DEFAULT=deepseek-v4-flash:cloud
HERMES_MODEL_FAST=deepseek-v4-flash:cloud
HERMES_MODEL_SMALL=deepseek-v4-flash:cloud
HERMES_MODEL_DEEP=glm-5.2:cloud
HERMES_PRIMARY_MODEL=deepseek-v4-flash:cloud
HERMES_FALLBACK_MODEL=glm-5.2:cloud
HERMES_CHECKER_MODEL=deepseek-v4-flash:cloud
HERMES_MAKER_MODEL=deepseek-v4-flash:cloud
HERMES_JUDGE_MODEL=glm-5.2:cloud

# Ollama Cloud is allowed because it runs through local Ollama API
HERMES_ALLOW_CLOUD_FALLBACK=1
HERMES_ALLOW_AUTO_CLOUD=true
HERMES_REQUIRE_MANUAL_CLOUD_APPROVAL=false

HERMES_MIN_CONTEXT_TOKENS=64000
HERMES_FAST_CONTEXT_LENGTH=1048576
HERMES_DEFAULT_CONTEXT_LENGTH=1048576
HERMES_MAX_DEFAULT_TOKENS=4096
HERMES_MAX_DEEP_TOKENS=8192
HERMES_MAX_AGENT_SECONDS=120
HERMES_MAX_LOCAL_CONCURRENCY=1

# Allow Ollama Cloud models for auto fallback
HERMES_FORBIDDEN_AUTO_FALLBACK_MODELS=*:cloud

# Task routing — Ollama Cloud primaries
HERMES_TASK_REASONING_PRIMARY=glm-5.2:cloud
HERMES_TASK_REASONING_FALLBACK=deepseek-v4-flash:cloud

HERMES_TASK_CODE_PRIMARY=deepseek-v4-flash:cloud
HERMES_TASK_CODE_FALLBACK=glm-5.2:cloud

HERMES_TASK_AGENT_LOOP_PRIMARY=glm-5.2:cloud
HERMES_TASK_AGENT_LOOP_FALLBACK=deepseek-v4-flash:cloud

HERMES_TASK_BULK_PRIMARY=deepseek-v4-flash:cloud
HERMES_TASK_BULK_FALLBACK=glm-5.2:cloud

# Safety
HERMES_NO_TOOL_MODELS=deepseek-r1,deepseek-coder,phi-2,codellama,starcoder,falcon,orca-mini,tinyllama,stablelm,vicuna,wizardcoder
HERMES_TOOL_ERROR_PATTERNS=does not support tools,does not support tool,400.*tools
