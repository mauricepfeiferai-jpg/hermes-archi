# Hermes model policy — 16GB Mac: no local Ollama models by default.
HERMES_MODEL_DEFAULT=hermes-local-emergency:latest
HERMES_MODEL_FAST=hermes-local-emergency:latest
HERMES_MODEL_SMALL=hermes-local-emergency:latest
HERMES_MODEL_DEEP=hermes-local-emergency:latest
HERMES_PRIMARY_MODEL=hermes-local-emergency:latest
HERMES_FALLBACK_MODEL=hermes-local-emergency:latest
HERMES_CHECKER_MODEL=hermes-local-emergency:latest
HERMES_MAKER_MODEL=hermes-local-emergency:latest
HERMES_JUDGE_MODEL=hermes-local-emergency:latest
HERMES_ALLOW_CLOUD_FALLBACK=0
HERMES_ALLOW_AUTO_CLOUD=false
HERMES_REQUIRE_MANUAL_CLOUD_APPROVAL=true
HERMES_MIN_CONTEXT_TOKENS=64000
HERMES_FAST_CONTEXT_LENGTH=65536
HERMES_DEFAULT_CONTEXT_LENGTH=65536
HERMES_MAX_DEFAULT_TOKENS=4096
HERMES_MAX_DEEP_TOKENS=8192
HERMES_MAX_AGENT_SECONDS=60
HERMES_MAX_LOCAL_CONCURRENCY=1
HERMES_FORBIDDEN_AUTO_FALLBACK_MODELS=glm-5.2:cloud,deepseek-v4-flash:cloud,kimi-k2.7-code:cloud

# --- DOWNGRADE MAP (ported from core/openclaw-stability-context) ---
# When task complexity=low, use cheaper model. Format: EXPENSIVE=CHEAP
# Hermes gateway reads these to auto-downgrade for simple tasks
# (title generation, compression, triage, approval, mcp calls)
HERMES_DOWNGRADE_north-mini-code-1.0:q4_K_M=hermes-local-emergency:latest
HERMES_DOWNGRADE_qwen3:32b=hermes-local-emergency:latest
HERMES_DOWNGRADE_qwen3:30b-a3b=hermes-local-emergency:latest
HERMES_DOWNGRADE_mistral:7b=mistral:7b
HERMES_DOWNGRADE_llama3.1:70b=llama3.1:8b
HERMES_DOWNGRADE_llama3.1:8b=llama3.1:8b
HERMES_DOWNGRADE_gemma3:27b=gemma3:12b
HERMES_DOWNGRADE_deepseek-v4:latest=deepseek-v4:latest
# Cloud downgrades (only used when HERMES_ALLOW_CLOUD_FALLBACK=1)
HERMES_DOWNGRADE_claude-sonnet-4-5=claude-3-5-haiku-20241022
HERMES_DOWNGRADE_claude-opus-4-6=claude-sonnet-4-5
HERMES_DOWNGRADE_gpt-4.1-2025-04-14=gpt-4.1-mini-2025-04-14
HERMES_DOWNGRADE_gemini-2.5-pro-preview-03-25=gemini-2.5-flash-preview-04-17

# --- TOOL DETECTION (ported from core/fix-deepseek-telegram-tools) ---
# Models that do NOT support function/tool calling.
# Hermes gateway skips tool injection for these models to prevent crashes.
# Comma-separated regex patterns matched case-insensitive against model name.
HERMES_NO_TOOL_MODELS=deepseek-r1,deepseek-coder,phi-2,codellama,starcoder,falcon,orca-mini,tinyllama,stablelm,vicuna,wizardcoder

# Error strings that indicate runtime tool-not-supported (catch-all fallback).
# If any of these appear in an API error, Hermes retries without tools.
HERMES_TOOL_ERROR_PATTERNS=does not support tools,does not support tool,400.*tools


# --- CHINESE STACK PRIMARY ROUTING (added 2026-06-29) ---
# Task-based primary/fallback model selection for 87% cost-cut migration.
# Fallback models are Western and only used when HERMES_ALLOW_CLOUD_FALLBACK=1
# or when explicitly approved.

HERMES_TASK_REASONING_PRIMARY=glm-5.2:cloud
HERMES_TASK_REASONING_FALLBACK=deepseek-v4-flash:cloud

HERMES_TASK_CODE_PRIMARY=deepseek-v4-flash:cloud
HERMES_TASK_CODE_FALLBACK=glm-5.2:cloud

HERMES_TASK_AGENT_LOOP_PRIMARY=glm-5.2:cloud
HERMES_TASK_AGENT_LOOP_FALLBACK=deepseek-v4-flash:cloud

HERMES_TASK_BULK_PRIMARY=deepseek-v4-flash:cloud
HERMES_TASK_BULK_FALLBACK=glm-5.2:cloud

HERMES_TASK_IMAGE_PRIMARY=wan-2.5
HERMES_TASK_IMAGE_FALLBACK=gpt-image-2

HERMES_TASK_VIDEO_PRIMARY=kling-3.0
HERMES_TASK_VIDEO_FALLBACK=sora-2

# Safety: Chinese primaries are API-only unless marked local-capable.
# Local-runnable flag controls whether Hermes may route to local Ollama.
HERMES_CHINESE_LOCAL_CAPABLE=qwen-3.7-max,glm-5.2,mimo-v2.5
