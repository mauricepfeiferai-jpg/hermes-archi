# ============================================
# AI EMPIRE - Environment Configuration
# ============================================
# ALLES KOSTENLOS - Kein API Key nötig!
# ============================================

# --- Telegram Bot (GRATIS von @BotFather) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# --- LLM Backend (Ollama - lokal, gratis, open source) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# --- Anthropic / Claude API (OPTIONAL - für bessere Qualität) ---
# Wenn gesetzt wird Anthropic bevorzugt, Ollama als Fallback
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- Redis (internal) ---
REDIS_URL=redis://redis:6379/0

# --- iCloud Sync (rclone - gratis) ---
ICLOUD_ENABLED=true
ICLOUD_REMOTE_NAME=icloud
ICLOUD_SYNC_PATH=/empire/results/

# --- Dropbox Sync (rclone - optional) ---
DROPBOX_ENABLED=false
DROPBOX_REMOTE_NAME=dropbox

# --- X/Twitter Analysis (gratis - yt-dlp + scraping) ---
X_ANALYSIS_ENABLED=true

# --- Whisper Transcription (lokal, gratis) ---
# Optionen: tiny, base, small, medium, large
WHISPER_MODEL=base

# --- Server ---
EMPIRE_DATA_DIR=/empire
SERVER_TIMEZONE=Europe/Berlin

# --- Portainer ---
PORTAINER_ADMIN_PASSWORD=changeme
