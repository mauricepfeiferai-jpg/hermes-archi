# Polymarket QPTS Configuration
# NEVER commit .env with real keys!

# Wallet (Polygon mainnet)
POLYGON_PRIVATE_KEY=0x_your_private_key_here

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# Polymarket Config
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Trading Parameters
START_CAPITAL=600.0
KELLY_FRACTION=0.25
MAX_DRAWDOWN=0.20
PAPER_MODE=true
SINGLE_CYCLE=false
CYCLE_INTERVAL_MINUTES=15

# Safety Thresholds
MIN_SHARPE_FOR_LIVE=1.5
MIN_CYCLES_PAPER=50
